# =============================================================================
# .env.example
# このファイルをコピーして `.env.local` を作成し、値を埋めてください。
# `.env.local` は .gitignore でコミット対象外です。
# Vercel ダッシュボードにも同じ環境変数を設定する必要があります。
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Project Settings → API から取得
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Image Generation Provider
# Phase A: "gemini" (無料Tier利用)
# Phase B: "openai" / "flux" 等で比較後切替
# -----------------------------------------------------------------------------
IMAGE_GEN_PROVIDER=gemini

# Gemini API (Google AI Studio: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenAI (Phase B 以降、有料テスト用)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Google Cloud Vision API (顔判定・無料 1000 ユニット/月)
# Google Cloud Console → APIとサービス → 認証情報
# -----------------------------------------------------------------------------
GOOGLE_VISION_API_KEY=

# -----------------------------------------------------------------------------
# Print Provider
# - "suzuri": 本番。SUZURI API を呼び、ステッカー商品を作成する
# - "stub":   開発用。API を呼ばずダミー URL を返す
# 将来: "stripe" (自前印刷 + Stripe決済)
# -----------------------------------------------------------------------------
PRINT_PROVIDER=suzuri

# SUZURI API トークン (https://suzuri.jp/developer/apps から発行)
# read + write スコープが必要
SUZURI_API_TOKEN=
